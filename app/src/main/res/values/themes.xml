<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Classschuldeapp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_editorial</item>
        <item name="colorSecondary">@color/secondary_teal</item>
        <item name="colorSecondaryContainer">@color/nav_indicator</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_card</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_dim</item>
        <item name="colorOnPrimary">@color/primary_variant</item>
        <item name="colorTertiary">@color/accent_lavender</item>
        <item name="colorError">@color/error_red</item>
    </style>

    <style name="Theme.Classschuldeapp" parent="Base.Theme.Classschuldeapp" />

    <style name="EditorialDisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface_light</item>
    </style>

    <style name="EditorialSubtitle" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/secondary_teal</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PillShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="DayPillActive" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/primary_editorial</item>
        <item name="android:background">@drawable/active_day_pill_bg</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="DayPillInactive" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/on_surface_dim</item>
        <item name="android:background">@drawable/inactive_day_pill_bg</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#FF1E3F35</item>
        <item name="shapeAppearance">@style/NavPillShape</item>
        <item name="android:width">64dp</item>
        <item name="android:height">38dp</item>
    </style>

    <style name="NavPillShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>