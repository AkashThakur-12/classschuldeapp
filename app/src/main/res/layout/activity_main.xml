<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/surface_container"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:id="@+id/nav_item_home"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView
                    android:id="@+id/nav_icon_home"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home"
                    android:tint="@color/on_surface_dim"
                    tools:ignore="ContentDescription" />
                <TextView
                    android:id="@+id/nav_text_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOME"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/on_surface_dim" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_item_chatbot"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView
                    android:id="@+id/nav_icon_chatbot"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_assistant"
                    android:tint="@color/on_surface_dim"
                    tools:ignore="ContentDescription" />
                <TextView
                    android:id="@+id/nav_text_chatbot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ASSISTANT"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/on_surface_dim" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_item_history"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView
                    android:id="@+id/nav_icon_history"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_history"
                    android:tint="@color/on_surface_dim"
                    tools:ignore="ContentDescription" />
                <TextView
                    android:id="@+id/nav_text_history"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HISTORY"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/on_surface_dim" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_item_profile"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView
                    android:id="@+id/nav_icon_profile"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_profile"
                    android:tint="@color/on_surface_dim"
                    tools:ignore="ContentDescription" />
                <TextView
                    android:id="@+id/nav_text_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFILE"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/on_surface_dim" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
