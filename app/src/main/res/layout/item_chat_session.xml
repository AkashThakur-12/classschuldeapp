<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_container"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnDeleteChat"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sessionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat Session"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface_light"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/sessionDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="12sp"
                android:textColor="@color/on_surface_dim" />

            <TextView
                android:id="@+id/sessionPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview of last message..."
                android:textSize="13sp"
                android:textColor="@color/on_surface_dim"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnDeleteChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="10dp"
            android:background="@drawable/delete_icon_bg"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF5252"
            android:contentDescription="Delete Chat" />

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
